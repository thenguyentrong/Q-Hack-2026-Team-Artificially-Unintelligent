# Agnes Competitor Layer Configuration
# Copy this file to .env and fill in your values.

# Google Gemini API key (required for Phases 5+)
GEMINI_API_KEY=

# Gemini model to use (default: gemini-2.5-pro)
GEMINI_MODEL=gemini-2.5-pro

# Maximum number of supplier candidates to return (default: 10)
COMPETITOR_MAX_CANDIDATES=10

# Enable candidate ranking (default: true)
COMPETITOR_RANKING_ENABLED=true

# --- Search Configuration ---

# Google Custom Search API key (required for real search)
GOOGLE_API_KEY=
# Google Custom Search Engine ID (required for real search)
GOOGLE_CSE_ID=

# Search engine: auto, google, mock (default: auto)
# auto = use Google if keys are set, otherwise mock
COMPETITOR_SEARCH_ENGINE=auto

# Results per search query (default: 10, Google max is 10)
COMPETITOR_SEARCH_RESULTS_PER_QUERY=10

# Delay between search queries in seconds (default: 1.0)
COMPETITOR_SEARCH_DELAY=1.0
